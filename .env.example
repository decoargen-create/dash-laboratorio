# Copiá este archivo como .env y completá con tus valores reales.
# NO subas .env al repositorio — ya está ignorado por .gitignore.

# ============================================================
# Chatbot con IA (api/chat.js, api/insights.js, api/analytics.js)
# ============================================================
# API key de Anthropic (https://console.anthropic.com).
# En producción (Vercel), configurala en Settings → Environment Variables.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Auth con magic link (api/auth.js)
# ============================================================
# Secret random para firmar los tokens (HMAC-SHA256). 32 bytes en hex.
# Generar con: openssl rand -hex 32
# Si cambiás este valor, se invalidan todas las sesiones activas.
AUTH_SECRET=

# Emails que van a tener rol admin (lista separada por comas, lowercase).
# El resto caerá al rol 'mentor'.
AUTH_ADMIN_EMAILS=vos@ejemplo.com

# Whitelist de emails autorizados a loguear (lista separada por comas).
# Si queda vacío, cualquier email puede pedir el magic link — dejalo así
# sólo mientras estés configurando; en prod completá con los permitidos.
AUTH_ALLOWED_EMAILS=vos@ejemplo.com,otro@ejemplo.com

# URL pública del sitio, usada para armar el link en los emails.
# Opcional: si no se setea, se usa el Origin del request.
# Ejemplo: https://laboratorio-viora.vercel.app
APP_URL=

# ============================================================
# Envío de mails (Resend — https://resend.com)
# ============================================================
# API key de Resend. Tier gratuito: 100 mails/día, 3k/mes.
# Si no se configura, api/auth.js devuelve el link en la response (útil
# para setup inicial, NO para producción).
RESEND_API_KEY=

# "From" que aparece en los emails. Para usar dominio propio hay que
# verificarlo en Resend primero; si no, usar onboarding@resend.dev como default.
AUTH_FROM=Laboratorio Viora <onboarding@resend.dev>
