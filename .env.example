# Copiá este archivo como .env y completá con tus valores reales.
# NO subas .env al repositorio — ya está ignorado por .gitignore.

# ============================================================
# Chatbot con IA (api/chat.js, api/insights.js, api/analytics.js)
# ============================================================
# API key de Anthropic (https://console.anthropic.com).
# En producción (Vercel), configurala en Settings → Environment Variables.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Auth (api/auth.js) — MÉTODO PRINCIPAL: usuario + contraseña
# ============================================================
# Secret random para firmar los tokens de sesión (HMAC-SHA256).
# Generar con: openssl rand -hex 32
# Si cambiás este valor, se invalidan todas las sesiones activas.
AUTH_SECRET=

# Usuarios habilitados. JSON array en UNA sola línea.
# Cada usuario: { u: username, n: nombre display, r: 'admin' | 'mentor', h: "<salt>$<hash>" }
# Para generar el hash de una contraseña:
#   node scripts/hash-password.mjs miPasswordSegura123
# Y pegá el output en el campo "h".
AUTH_USERS=[{"u":"admin","n":"Administrador","r":"admin","h":"PEGAR_HASH_ACA"}]

# ============================================================
# Auth por email (magic link) — OPCIONAL, método alternativo
# ============================================================
# Si querés permitir login también por email (además de user+pass),
# completá estas. Si no, dejá todo en blanco.

# Emails que van a tener rol admin al loguear por email (CSV lowercase).
AUTH_ADMIN_EMAILS=

# Whitelist de emails autorizados a pedir magic link (CSV).
# Si queda vacío, cualquier email puede pedir el link — no dejes así en prod.
AUTH_ALLOWED_EMAILS=

# URL pública del sitio, usada para armar el link en los emails.
APP_URL=

# Resend — https://resend.com — para enviar los emails. Sin esto el endpoint
# devuelve el link en la response (sólo para setup / dev).
RESEND_API_KEY=
AUTH_FROM=Laboratorio Viora <onboarding@resend.dev>
