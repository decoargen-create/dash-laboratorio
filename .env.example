# Copiá este archivo como .env y completá con tus valores reales.
# NO subas .env al repositorio — ya está ignorado por .gitignore.

# ============================================================
# Chatbot con IA (api/chat.js, api/insights.js, api/analytics.js)
# ============================================================
# API key de Anthropic (https://console.anthropic.com).
# En producción (Vercel), configurala en Settings → Environment Variables.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# OpenAI — transcripción de videos (Whisper) + generación de
# creativos estáticos (gpt-image-1)
# ============================================================
# Usada por api/marketing/deep-analyze.js (Whisper transcribe los videos
# de ads ganadores) y api/marketing/generate-creative.js (gpt-image-1
# genera la imagen final del ad desde el brief de la Bandeja).
# Si falta, el pipeline igual corre pero sin transcripción ni creativos.
OPENAI_API_KEY=

# ============================================================
# Apify — scraping de la Meta Ad Library (ads de competidores)
# ============================================================
# Usada por api/marketing/apify-ingest.js y suggest-competitors.js.
APIFY_TOKEN=
# Opcional: actor alternativo (default: apify/facebook-ads-scraper).
APIFY_ACTOR_ID=

# ============================================================
# Auth (api/auth.js) — MÉTODO PRINCIPAL: usuario + contraseña
# ============================================================
# Secret random para firmar los tokens de sesión (HMAC-SHA256).
# Generar con: openssl rand -hex 32
# Si cambiás este valor, se invalidan todas las sesiones activas.
AUTH_SECRET=

# Usuarios habilitados. JSON array en UNA sola línea.
# Cada usuario: { u: username, n: nombre display, r: 'admin' | 'mentor', h: "<salt>$<hash>" }
# Para generar el hash de una contraseña:
#   node scripts/hash-password.mjs miPasswordSegura123
# Y pegá el output en el campo "h".
AUTH_USERS=[{"u":"admin","n":"Administrador","r":"admin","h":"PEGAR_HASH_ACA"}]

# ============================================================
# Auth por email (magic link) — OPCIONAL, método alternativo
# ============================================================
# Si querés permitir login también por email (además de user+pass),
# completá estas. Si no, dejá todo en blanco.

# Emails que van a tener rol admin al loguear por email (CSV lowercase).
AUTH_ADMIN_EMAILS=

# Whitelist de emails autorizados a pedir magic link (CSV).
# Si queda vacío, cualquier email puede pedir el link — no dejes así en prod.
AUTH_ALLOWED_EMAILS=

# URL pública del sitio, usada para armar el link en los emails.
APP_URL=

# Resend — https://resend.com — para enviar los emails. Sin esto el endpoint
# devuelve el link en la response (sólo para setup / dev).
RESEND_API_KEY=
AUTH_FROM=Laboratorio Viora <onboarding@resend.dev>

# ============================================================
# Automatización de renovación de creativos (cron diario)
# ============================================================
# Config del producto que el cron va a procesar cada día a las 12:00 UTC
# (09:00 Argentina). JSON en una sola línea. Desde la UI (Marketing → Meta
# Ads → Automatización) tenés todos los IDs — armalo con esa info.
#
# Shape:
#   {
#     "accountId":   "act_1234567890",
#     "campaignId":  "1234567890",
#     "baseAdsetId": "1234567890",
#     "igId":        "17841...",
#     "pageId":      "10015...",
#     "threshold":   50,
#     "pinnedPosts": 0,
#     "webhookUrl":  "https://discord.com/api/webhooks/...",
#     "enabled":     true
#   }
CREATIVE_REFRESH_CONFIG=

# Access token de servicio para el cron (no tiene cookie de user).
# Idealmente un long-lived token de un System User del Business Manager —
# no expira. Sino, un user long-lived dura ~60 días y hay que rotarlo.
META_SYSTEM_ACCESS_TOKEN=

# Opcional: Bearer secret para disparar el cron manualmente desde un
# scheduler externo. Vercel Cron no necesita esta var (usa el header
# `x-vercel-cron: 1`).
IG_REFRESH_CRON_SECRET=
