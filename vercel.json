{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/marketing/generate.js":        { "maxDuration": 300 },
    "api/marketing/apify-ingest.js":    { "maxDuration": 300 },
    "api/marketing/deep-analyze.js":    { "maxDuration": 240 },
    "api/marketing/generate-ideas.js":  { "maxDuration": 300 },
    "api/marketing/generate-copy.js":   { "maxDuration": 120 },
    "api/marketing/generate-creative.js": { "maxDuration": 180 },
    "api/marketing/crear-creativo-referencial.js": { "maxDuration": 300 },
    "api/marketing/crear-imagen-desde-idea.js":    { "maxDuration": 300 },
    "api/marketing/adapt-guion.js":     { "maxDuration": 60 },
    "api/marketing/copilot.js":         { "maxDuration": 60 },
    "api/marketing/score-hooks.js":     { "maxDuration": 60 },
    "api/marketing/match-product-ads.js": { "maxDuration": 60 },
    "api/marketing/suggest-competitors.js": { "maxDuration": 180 },
    "api/marketing/post-research-analysis.js": { "maxDuration": 60 },
    "api/marketing/creatives.js": { "maxDuration": 180 },
    "api/marketing/adapt-inspiracion.js": { "maxDuration": 120 },
    "api/marketing/resolve-fb-page.js": { "maxDuration": 30 },
    "api/marketing/proxy-image.js": { "maxDuration": 30 },
    "api/marketing/ocr-ad.js": { "maxDuration": 180 },
    "api/marketing/transcribe-ad.js": { "maxDuration": 240 },
    "api/marketing/transcribir-video.js": { "maxDuration": 240 },
    "api/marketing/adaptar-guion-video.js": { "maxDuration": 120 },
    "api/marketing/search-ads.js": { "maxDuration": 30 },
    "api/marketing/boards.js": { "maxDuration": 30 },
    "api/meta/[action].js": { "maxDuration": 60 },
    "api/meta/ad-library.js": { "maxDuration": 60 },
    "api/acta.js": { "maxDuration": 60 },
    "api/actas/sync.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/meta/cron-creative-refresh", "schedule": "0 12 * * *" },
    { "path": "/api/actas/sync", "schedule": "0 9 * * *" }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/marketing/proxy-image",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    },
    {
      "source": "/api/((?!marketing/proxy-image).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(sw\\.js|workbox-.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
